[gd_scene load_steps=5 format=3]

[ext_resource type="Script" path="res://scripts/screens/home_tab.gd" id="1_script"]
[ext_resource type="Texture2D" path="res://assets/background/Main Background.png" id="2_hero"]
[ext_resource type="Theme" path="res://themes/void_slicer_theme.tres" id="3_theme"]
[ext_resource type="Texture2D" path="res://assets/ui/turret_phase1.png" id="4_turret"]

[node name="HomeTabRoot" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme = ExtResource("3_theme")
script = ExtResource("1_script")

[node name="Scroll" type="ScrollContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
horizontal_scroll_mode = 0

[node name="Content" type="VBoxContainer" parent="Scroll"]
custom_minimum_size = Vector2(1280, 0)
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 12

[node name="HeroRow" type="HBoxContainer" parent="Scroll/Content"]
custom_minimum_size = Vector2(0, 330)
layout_mode = 2
theme_override_constants/separation = 12

